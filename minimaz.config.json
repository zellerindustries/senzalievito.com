{
    "input": {
        "dir": "./src",
        "mapping": {
            "pages": "",
            "scripts": "",
            "styles": "",
            "public": ""
        },
        "externals": {
            "./node_modules/bootstrap-icons/font/fonts": "fonts"
        }
    },
    "output": {
        "dir": "./dist",
        "replace": {
            "../public/": "/public/",
            "<link rel=\"stylesheet\" href=\"styles/bootstrap-icons.css\" />": "",
            "<link rel=\"stylesheet\" href=\"../styles/bootstrap-icons.css\" />": "",
            "../node_modules/bootstrap-icons/font/fonts/bootstrap-icons.woff2": "/fonts/bootstrap-icons.woff2",
            "../node_modules/bootstrap-icons/font/fonts/bootstrap-icons.woff": "/fonts/bootstrap-icons.woff"
        },
        "css": {
            "bundling": true,
            "minify": true,
            "outFile": "style.css"
        },
        "html": {
            "minify": true
        },
        "js": {
            "bundling": true,
            "minify": true,
            "outFile": "script.js"
        },
        "ts": {
            "minify": true
        }
    }
}